{
  "require": {
      "doctrine/orm": "^3",
      "doctrine/dbal": "^4",
      "symfony/cache": "^7",
    "doctrine/migrations": "^3.9",
    "symfony/console": "^7.2",
    "league/route": "^6.2",
    "laminas/laminas-diactoros": "^3.8",
    "laminas/laminas-httphandlerrunner": "^2.13"
  },
  "autoload": {
      "psr-4": {
      "App\\": "src/",
      "Classes\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "*",
    "phpstan/phpstan": "^2.1"
  }
}
